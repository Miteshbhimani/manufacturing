<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_headless_section_form" model="ir.ui.view">
        <field name="name">headless.section.form</field>
        <field name="model">headless.section</field>
        <field name="arch" type="xml">
            <form string="Page Section">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="page_id"/>
                            <field name="component_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="title"/>
                            <field name="subtitle"/>
                            <field name="button_text"/>
                            <field name="button_link"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content" widget="html"/>
                        </page>
                        <page string="Media" name="media">
                            <field name="image_1920" widget="image" options="{'size': [300, 300]}"/>
                        </page>
                        <page string="Advanced JSON" name="advanced">
                            <field name="extra_json_data"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
